<div id="toast"></div>

<script>
function sanitize(s){ return (s||'').trim().toLowerCase().replace(/[^a-z0-9]/g,'').slice(0,20); }
window._sanitize = sanitize;
function onMetaInput(){ updateBadge(); }
function onTopicChange(){ updateBadge(); as(); }

window.clearPoster = function clearPoster(){
  const fields=['f-title','f-motive','f-question','f-hypo','f-bg1','f-bg2','f-proc','f-data','f-conc','f-climlink','f-disc','f-newq','f-refs'];
  fields.forEach(id=>{const el=document.getElementById(id);if(el)el.innerHTML='';});
  ['m-members','m-date'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.querySelectorAll('.pslot').forEach(slot=>{
    slot.dataset.img=''; slot.classList.remove('has');
    const img=slot.querySelector('img'); if(img) img.remove();
    if(!slot.querySelector('.pph')){
      const ph=document.createElement('div'); ph.className='pph';
      ph.innerHTML=`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="12" cy="12" r="3"/><path d="M8.5 5 10 3h4l1.5 2"/></svg><span>클릭하여 추가</span>`;
      slot.insertBefore(ph, slot.querySelector('.pov'));
    }
  });
  document.querySelectorAll('.pcap').forEach(cap=>cap.innerText='');
  document.querySelectorAll('.card[data-sid] .chdr').forEach(el=>el.style.background='');
}

function updateBadge(){
  const school=sanitize(document.getElementById('sel-school')?.value||'');
  const group=sanitize(document.getElementById('sel-group')?.value||'');
  const t=document.getElementById('sel-topic').value;
  const tag = (school||group) ? `[${school||'?'}/${group||'?'}]` : '';
  document.getElementById('h-badge').textContent = t ? `${tag} ${t}`.trim() : (tag?`${tag} 주제 미선택`:'학교코드·모둠코드·주제를 선택해주세요');
  document.getElementById('tdisplay').textContent = t ? t.replace(/^[^\uAC00-\uD7A3a-zA-Z0-9]+/,'').slice(0,12) : (tag||'미연결');
}

function fbConnect(){ if(window._fb_connect) window._fb_connect(); else localConnect(); }
function localConnect(){
  const school=sanitize(document.getElementById('sel-school').value);
  const group=sanitize(document.getElementById('sel-group').value);
  if(!school){toast('학교 코드를 입력하세요','w');return;}
  if(!group){toast('모둠 코드를 입력하세요','w');return;}
  updateBadge(); toast(`[${school}/${group}] 설정됨 (로컬)`,'ok');
}
function fbSave(){ if(window._fb_save) window._fb_save(); else toast('Firebase 설정 필요','w'); }
function as(){ if(window._autosave) window._autosave(); }
function setSyncDot(on){ document.getElementById('sdot').className=on?'on':''; }

let curField=null, ftTimer=null;
document.addEventListener('focusin', e=>{
  const f=e.target.closest('.f'); if(!f)return;
  curField=f; clearTimeout(ftTimer);
  const ft=document.getElementById('ftb'); ft.classList.add('on');
  const r=f.getBoundingClientRect(); const ftH=44;
  let top=r.top-ftH-6;
  if(top<58) top=r.bottom+6;
  if(top+ftH>window.innerHeight-10) top=window.innerHeight-ftH-10;
  ft.style.top=top+'px';
  ft.style.left=Math.min(Math.max(r.left,8), window.innerWidth-278)+'px';
  document.getElementById('fsz-val').textContent=(f.dataset.fs||'13')+'px';
});
document.addEventListener('focusout', ()=>{ ftTimer=setTimeout(()=>{ if(!document.activeElement?.closest('#ftb')) document.getElementById('ftb').classList.remove('on'); },180); });
document.getElementById('ftb').addEventListener('mousedown',e=>e.preventDefault());
function fsz(d){ if(!curField)return; fszSet(Math.max(9,Math.min(32,parseInt(curField.dataset.fs||"13")+d))); }
function fszSet(s){ if(!curField)return; curField.dataset.fs=s; curField.style.fontSize=s+'px'; document.getElementById('fsz-val').textContent=s+'px'; as(); }

const SWATCHES=['linear-gradient(90deg,#0b3d6b,#1565a8)','linear-gradient(90deg,#1a2a5e,#2a4aaa)','linear-gradient(90deg,#0d2137,#0b5ea8)','linear-gradient(90deg,#0c5a5a,#0c8a7a)','linear-gradient(90deg,#1a5c38,#1a8a50)','linear-gradient(90deg,#0a3828,#1a7a50)','linear-gradient(90deg,#8c2e08,#c04818)','linear-gradient(90deg,#7a1a10,#c03020)','linear-gradient(90deg,#a04010,#d06820)','linear-gradient(90deg,#381860,#6030a0)','linear-gradient(90deg,#2a1050,#5828a0)','linear-gradient(90deg,#4a1060,#8020a0)','linear-gradient(90deg,#1a1a2e,#2a2a50)','linear-gradient(90deg,#1e2a38,#2a4060)','linear-gradient(90deg,#252525,#404060)','linear-gradient(90deg,#5a3800,#a06800)','linear-gradient(90deg,#6a3010,#b05020)','linear-gradient(90deg,#3a2800,#806000)'];
let curSid=null;
(()=>{ const sw=document.getElementById('cp-sw'); SWATCHES.forEach(c=>{ const d=document.createElement('div'); d.className='sw'; d.style.background=c; d.style.border='2px solid rgba(255,255,255,0.15)'; d.onclick=()=>applyColor(c); sw.appendChild(d); }); })();
function openCP(e, sid){ e.stopPropagation(); curSid=sid; const p=document.getElementById('cpop'); const r=e.currentTarget.getBoundingClientRect(); p.style.top=(r.bottom+window.scrollY+5)+'px'; p.style.left=Math.min(r.left, window.innerWidth-220)+'px'; p.classList.add('on'); }
function applyColor(c){ if(!curSid)return; const el=document.querySelector(`.card[data-sid="${curSid}"] .chdr`); if(el) el.style.background=c; as(); }
function resetColor(){ if(!curSid)return; const el=document.querySelector(`.card[data-sid="${curSid}"] .chdr`); if(el) el.style.background=''; document.getElementById('cpop').classList.remove('on'); as(); }
document.addEventListener('click',e=>{ if(!e.target.closest('#cpop')&&!e.target.closest('.cbtn')) document.getElementById('cpop').classList.remove('on'); });

function initPhotoSlots(){ const area=document.getElementById('photo-area'); area.innerHTML=''; for(let i=0;i<4;i++) createSlot(area); }
function createSlot(area){
  const wrap=document.createElement('div'); wrap.className='ps';
  const slot=document.createElement('div'); slot.className='pslot'; slot.dataset.img='';
  slot.innerHTML=`<div class="pph"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="12" cy="12" r="3"/><path d="M8.5 5 10 3h4l1.5 2"/></svg><span>클릭하여 추가</span></div><div class="pov"><span>🔄 교체</span></div><input type="file" accept="image/*" style="display:none">`;
  const inp=slot.querySelector('input');
  slot.addEventListener('click',()=>inp.click());
  inp.addEventListener('change',e=>{
    const f=e.target.files[0]; if(!f)return;
    const img=new Image(), url=URL.createObjectURL(f);
    img.onload=()=>{
      const canvas=document.createElement('canvas'); const max=600; let w=img.width,h=img.height;
      if(w>max){h=h*max/w;w=max;} canvas.width=w; canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      const data=canvas.toDataURL('image/jpeg',.75);
      slot.dataset.img=data; renderPhoto(slot,data); as(); URL.revokeObjectURL(url);
    };
    img.src=url;
  });
  const cap=document.createElement('div'); cap.className='pcap'; cap.contentEditable='true'; cap.spellcheck=false; cap.oninput=as;
  wrap.appendChild(slot); wrap.appendChild(cap); area.appendChild(wrap);
}
function renderPhoto(slot,src){ let img=slot.querySelector('img'); if(!img){img=document.createElement('img');slot.insertBefore(img,slot.firstChild);} img.src=src; slot.querySelector('.pph')?.remove(); slot.classList.add('has'); }
initPhotoSlots();

function collectLocal(){
  const photos=[],caps=[];
  document.querySelectorAll('.ps').forEach(w=>{ photos.push(w.querySelector('.pslot').dataset.img||''); caps.push(w.querySelector('.pcap').innerText||''); });
  const sz={},cl={};
  document.querySelectorAll('[data-fk]').forEach(e=>sz[e.dataset.fk]=e.dataset.fs||'13');
  document.querySelectorAll('.card[data-sid]').forEach(e=>cl[e.dataset.sid]=e.querySelector('.chdr').style.background||'');
  const g=id=>document.getElementById(id)?.innerHTML||''; const v=id=>document.getElementById(id)?.value||'';
  return { title:g('f-title'), members:v('m-members'), date:v('m-date'),
    school:v('sel-school'), group:v('sel-group'), topic:v('sel-topic'),
    motive:g('f-motive'), question:g('f-question'), hypo:g('f-hypo'),
    bg1:g('f-bg1'), bg2:g('f-bg2'), proc:g('f-proc'), data:g('f-data'),
    conc:g('f-conc'), climlink:g('f-climlink'), disc:g('f-disc'),
    refs:g('f-refs'), newq:g('f-newq'), photos, caps, sz, cl, savedAt:new Date().toISOString() };
}
function applyLocal(d){
  const sh=(id,h)=>{const e=document.getElementById(id);if(e)e.innerHTML=h||'';};
  const sv=(id,v)=>{const e=document.getElementById(id);if(e)e.value=v||'';};
  sh('f-title',d.title); sv('m-members',d.members); sv('m-date',d.date);
  sv('sel-school',d.school||''); sv('sel-group',d.group||''); sv('sel-topic',d.topic||'');
  updateBadge();
  ['motive','question','hypo','bg1','bg2','proc','data','conc','climlink','disc','newq','refs'].forEach(k=>sh('f-'+k, d[k]||''));
  if(d.sz) Object.entries(d.sz).forEach(([k,v])=>{ const el=document.querySelector(`[data-fk="${k}"]`); if(el){el.dataset.fs=v;el.style.fontSize=v+'px';} });
  if(d.cl) Object.entries(d.cl).forEach(([k,v])=>{ const el=document.querySelector(`.card[data-sid="${k}"] .chdr`); if(el&&v)el.style.background=v; });
  if(d.photos?.length){
    const slots=document.querySelectorAll('.pslot');
    slots.forEach((slot,i)=>{ if(d.photos[i]){slot.dataset.img=d.photos[i];renderPhoto(slot,d.photos[i]);} });
    document.querySelectorAll('.pcap').forEach((cap,i)=>{ if(d.caps?.[i]) cap.innerText=d.caps[i]; });
  }
}
function dlJSON(){
  const t=(document.getElementById('sel-topic').value||'미선택').replace(/[^\uAC00-\uD7A3a-zA-Z0-9]/g,'')||'주제';
  const s=sanitize(document.getElementById('sel-school').value)||'학교';
  const g=sanitize(document.getElementById('sel-group').value)||'모둠';
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([JSON.stringify(collectLocal(),null,2)],{type:'application/json'}));
  a.download=`포스터_${s}_${g}_${t}.json`; a.click(); toast('💾 백업 완료','ok');
}
function ldJSON(ev){
  const f=ev.target.files[0]; if(!f)return;
  const r=new FileReader();
  r.onload=e=>{ try{ applyLocal(JSON.parse(e.target.result)); toast('📂 불러오기 완료','ok'); } catch{ toast('파일 오류','e'); } };
  r.readAsText(f);
}

let toastT;
function toast(msg,type='ok'){
  const el=document.getElementById('toast'); el.textContent=msg; el.className='on '+type;
  clearTimeout(toastT); toastT=setTimeout(()=>el.className='',2200);
  if(type==='ok') setSyncDot(true);
}
</script>
